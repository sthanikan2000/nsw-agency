# Agency Portal Configuration

# Frontend Development Server Port
VITE_PORT=5173

# Branding Configuration Name
# Determines which dynamic JSON configuration to fetch at runtime (e.g. "npqs", "fcau", or "default").
# This will request the file "/configs/${VITE_BRANDING_NAME}.branding.json".
VITE_BRANDING_NAME=default

# Backend API Base URL
VITE_API_BASE_URL=http://localhost:8081

# Identity Provider (ThunderID)
VITE_IDP_BASE_URL=https://localhost:8090
VITE_IDP_CLIENT_ID=<AGENCY_PORTAL_CLIENT_ID>
VITE_APP_URL=http://localhost:5173
# OAuth scopes requested at login (comma-separated).
# The agency:* scopes cause the IdP to set aud=AGENCY_API on the access token
# and include the reviewer's granted permissions — required for the agency backend
# to accept the token once audience validation is enabled.
VITE_IDP_SCOPES=openid,profile,email,ou,role,agency:application:read,agency:application:review,agency:application:feedback,agency:consignment:read,agency:storage:read,agency:storage:write

# Required: Organization/OU handle for this portal instance (npqs | fcau | ird | cda).
# Serves two purposes:
#   1. Passed to ThunderIDProvider as `organizationHandle` — mandatory when a custom
#      domain is used and the base URL does not follow the /t/{orgHandle} pattern.
#   2. Used to restrict portal access — users whose id_token `ouHandle` claim does not
#      match this value will see an unauthorized screen.
VITE_IDP_EXPECTED_OU_HANDLE=<expected-ou-handle>

# Example values per portal:
# VITE_IDP_EXPECTED_OU_HANDLE=npqs   # National Plant Quarantine Service
# VITE_IDP_EXPECTED_OU_HANDLE=fcau   # Food Control Administration Unit
# VITE_IDP_EXPECTED_OU_HANDLE=ird    # Inland Revenue Department
# VITE_IDP_EXPECTED_OU_HANDLE=cda    # Coconut Development Authority
