# OGA Portal Configuration

# Frontend Development Server Port
VITE_PORT=5174

# Branding Configuration Name
# Determines which dynamic JSON configuration to fetch at runtime (e.g. "npqs", "fcau", or "default").
# This will request the file "/configs/${VITE_BRANDING_NAME}.branding.json".
VITE_BRANDING_NAME=default

# Backend API Base URL
VITE_API_BASE_URL=http://localhost:8081

# Identity Provider (Asgardeo/Thunder)
VITE_IDP_BASE_URL=https://localhost:8090
VITE_IDP_CLIENT_ID=<OGA_PORTAL_CLIENT_ID>
VITE_APP_URL=http://localhost:5174
# Optional: Override OAuth scopes (comma-separated, defaults to: openid,profile,email)
# VITE_IDP_SCOPES=openid,profile,email
# Optional: Platform type (defaults to: AsgardeoV2)
# VITE_IDP_PLATFORM=AsgardeoV2


########################################################################
# Example usage for different OGA portals:

# --- NPQS (National Plant Quarantine Service) ---
# cd portals/apps/oga-app

# export VITE_PORT=5174
# export VITE_BRANDING_PATH="./src/configs/npqs.yaml"
# export VITE_API_BASE_URL="http://localhost:8081"
# export VITE_IDP_BASE_URL="https://localhost:8090"
# export VITE_IDP_CLIENT_ID="OGA_PORTAL_APP_NPQS"
# export VITE_APP_URL="http://localhost:5174"

# pnpm run dev

# --- FCAU (Food Control Administration Unit) ---
# cd portals/apps/oga-app

# export VITE_PORT=5175
# export VITE_BRANDING_PATH="./src/configs/fcau.yaml"
# export VITE_API_BASE_URL="http://localhost:8082"
# export VITE_IDP_BASE_URL="https://localhost:8090"
# export VITE_IDP_CLIENT_ID="OGA_PORTAL_APP_FCAU"
# export VITE_APP_URL="http://localhost:5175"

# pnpm run dev

# -- IRD (Inland Revenue Department) ---
# cd portals/apps/oga-app

# export VITE_PORT=5176
# export VITE_BRANDING_PATH="./src/configs/ird.yaml"
# export VITE_API_BASE_URL="http://localhost:8083"
# export VITE_IDP_BASE_URL="https://localhost:8090"
# export VITE_IDP_CLIENT_ID="OGA_PORTAL_APP_IRD"
# export VITE_APP_URL="http://localhost:5176"

# pnpm run dev

# --- CDA (Coconut Development Authority) ---
# cd portals/apps/oga-app

# export VITE_PORT=5177
# export VITE_BRANDING_PATH="./src/configs/cda.yaml"
# export VITE_API_BASE_URL="http://localhost:8084"
# export VITE_IDP_BASE_URL="https://localhost:8090"
# export VITE_IDP_CLIENT_ID="OGA_PORTAL_APP_CDA"
# export VITE_APP_URL="http://localhost:5177"

# pnpm run dev
