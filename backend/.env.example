# Port the Agency server listens on
PORT=8081

# Database driver: sqlite | postgres
DB_DRIVER=sqlite

# SQLite settings (used if DB_DRIVER=sqlite)
DB_PATH=./agency_applications.db

# PostgreSQL settings (used if DB_DRIVER=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=nsw_agency_db
DB_SSLMODE=disable

# Path to SQL migration files directory
MIGRATION_DIR=./migrations

# Built-in defaults root. Always loaded as a flat-local source alongside the
# (optional) primary sources below; expected to contain task-configs/ and
# forms/ subdirectories with the fallback default.json / default_review.json
# bundled with the binary.
CONFIG_DIR=./data

# Fallback task config ID used when a request's taskCode has no registered config
DEFAULT_TASK_CONFIG_ID=default

# --- Forms primary source ---
# Layered ON TOP of the built-in defaults. The primary source wins on ID
# conflicts; if it has no entry for an ID, the built-in defaults serve it.
# FORMS_SOURCE_TYPE: "none" (default — only built-in defaults used),
# "local" (any directory; auto-detects manifest.json), or "github".
FORMS_SOURCE_TYPE=none
# Required when FORMS_SOURCE_TYPE=local. Any directory path. If the directory
# contains manifest.json with a {"byId":{id:"relpath"}} map (as in
# OpenNSW/one-trade-templates), blobs are loaded via the manifest; otherwise
# every *.json file in the directory is loaded with ID = filename.
FORMS_SOURCE_LOCAL_DIR=
# Required when FORMS_SOURCE_TYPE=github. owner/repo, e.g. OpenNSW/one-trade-templates
FORMS_SOURCE_GITHUB_REPO=
# Required when FORMS_SOURCE_TYPE=github. Branch name or commit SHA (pin a SHA in prod).
FORMS_SOURCE_GITHUB_REF=
# Optional. Repo-relative path to the manifest file. Defaults to manifest.json
# at the repo root. byId values inside the manifest are resolved relative to
# the manifest's directory.
FORMS_SOURCE_GITHUB_MANIFEST_PATH=
# Optional. Override the raw-content host (for tests or GitHub Enterprise).
FORMS_SOURCE_GITHUB_BASE_URL=
# Optional. Background manifest refresh interval as a Go duration (e.g. 5m). 0 disables.
FORMS_SOURCE_GITHUB_REFRESH_INTERVAL=0

# --- Task configs primary source ---
# Same shape as the forms source above. Production points this at
# OpenNSW/one-trade-agency-configs. That repo carries one manifest per agency
# (e.g. agency-configs/fcau/manifest.json) — set the per-agency MANIFEST_PATH accordingly.
TASK_CONFIGS_SOURCE_TYPE=none
TASK_CONFIGS_SOURCE_LOCAL_DIR=
TASK_CONFIGS_SOURCE_GITHUB_REPO=
TASK_CONFIGS_SOURCE_GITHUB_REF=
TASK_CONFIGS_SOURCE_GITHUB_MANIFEST_PATH=
TASK_CONFIGS_SOURCE_GITHUB_BASE_URL=
TASK_CONFIGS_SOURCE_GITHUB_REFRESH_INTERVAL=0

# Comma-separated list of allowed CORS origins (use * to allow all)
ALLOWED_ORIGINS=*

# NSW outbound API settings used for Agency -> NSW calls
NSW_API_BASE_URL=http://localhost:8080/api/v1

# OAuth2 client credentials (required) to hit the NSW API. These should correspond to a client registered in the OAuth2 provider that issues tokens for the NSW API.
NSW_CLIENT_ID=AGENCY_TO_NSW
NSW_CLIENT_SECRET=1234
NSW_TOKEN_URL=https://localhost:8090/oauth2/token

# Optional comma-separated scopes
# NSW_SCOPES=

# DEV-ONLY: set to true to skip TLS verification for OAuth2 token endpoint
# Keep false in production.
NSW_TOKEN_INSECURE_SKIP_VERIFY=false
